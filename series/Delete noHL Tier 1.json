{
  "name": "Delete: noHL Tier 1",
  "trackerPattern": "*",
  "trackerDomains": [
    "*"
  ],
  "conditions": {
    "schemaVersion": "1",
    "delete": {
      "enabled": true,
      "mode": "deleteWithFilesPreserveCrossSeeds",
      "condition": {
        "operator": "AND",
        "conditions": [
          {
            "field": "TAGS",
            "operator": "EQUAL",
            "value": "Tier1"
          },
          {
            "field": "TAGS",
            "operator": "EQUAL",
            "value": "noHL"
          },
          {
            "field": "COMPLETION_ON",
            "operator": "GREATER_THAN",
            "value": "1814400"
          },
          {
            "field": "LAST_ACTIVITY",
            "operator": "GREATER_THAN_OR_EQUAL",
            "value": "21600"
          },
          {
            "field": "NUM_COMPLETE",
            "operator": "GREATER_THAN_OR_EQUAL",
            "value": "3"
          },
          {
            "operator": "AND",
            "conditions": [
              {
                "field": "NAME",
                "operator": "MATCHES",
                "value": "(?i)(?:S\\d{1,3}|Season[\\s\\.]\\d{1,3})"
              },
              {
                "field": "NAME",
                "operator": "MATCHES",
                "value": "(?i)S\\d{1,3}E\\d{1,3}",
                "negate": true
              }
            ]
          }
        ]
      }
    }
  },
  "intervalSeconds": 14400
}